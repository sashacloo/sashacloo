    "flickity-as-nav-for": "^3.0.0",
    "flickity-fade": "^2.0.0",
    "flickity-imagesloaded": "^2.0.0",
    "nuxt": "^2.17.3",
    "sass": "^1.49.9",
    "sass-loader": "^10.4.1",
    "vue": "^2.7.16",
    "vue-observe-visibility": "^1.0.0",
